PROJECT_NAME="Medical Diagnosis API"
ENVIRONMENT=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1
JSON_LOGS=true
LOG_LEVEL=WARNING

# Public URL shown to browsers (no trailing slash)
PUBLIC_URL=http://localhost
FRONTEND_PORT=80

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=medical_diagnosis
POSTGRES_USER=medical_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery — required for async prediction tasks
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# AI model service
AI_SERVICE_URL=http://ai-model:5000

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp","image/tiff"]

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# DB pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT=30

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=20

# CORS — set to your frontend domain in production
CORS_ORIGINS=["http://localhost"]
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=["X-Trace-ID"]

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# Email (SMTP) — use Gmail App Password or SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@medscan.ai
SMTP_FROM_NAME=MedScan AI
SMTP_TLS=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=2

# Storage — set to "s3" for Cloudflare R2 / AWS S3
STORAGE_BACKEND=local
S3_BUCKET_NAME=medscan-uploads
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Cloudflare R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
# Public CDN URL for file access (optional)
S3_PUBLIC_URL=

# Sentry — leave blank to disable
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
